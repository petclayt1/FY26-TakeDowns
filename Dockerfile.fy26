# Alternative Dockerfile when the build context is the repository root
# (some DigitalOcean / CI setups only allow context: /).
#
# Build: docker build -f Dockerfile.fy26 -t fy26-takedown .
FROM nginx:1.27-alpine
COPY fy26-takedown/nginx.conf /etc/nginx/conf.d/default.conf
COPY fy26-takedown/index.html /usr/share/nginx/html/index.html
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
